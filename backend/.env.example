HOST=0.0.0.0
PORT=8010

# Frontend dev proxy from backend -> Vite
DEV_PROXY=1
VITE_ORIGIN=http://127.0.0.1:5173
# VITE_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Auth
AUTH_COOKIE_SECURE=0

# Storage backend
# Runtime backend is Postgres-only.
PIM_STORAGE_BACKEND=postgres
# DATABASE_URL=postgresql://user:pass@db-host:5432/db_name?sslmode=verify-full&sslrootcert=/absolute/path/to/ca.crt
# PIM_DATABASE_URL=postgresql://user:pass@db-host:5432/db_name?sslmode=verify-full&sslrootcert=/absolute/path/to/ca.crt

# Object storage (S3)
S3_ENABLED=1
S3_ENDPOINT=https://s3.example.com
S3_REGION=ru-1
S3_BUCKET=your-bucket
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=1

# LLM (free/local via Ollama, OpenAI-compatible API)
LLM_API_BASE=http://localhost:11434/v1
LLM_MODEL=llama3.1:8b-instruct
LLM_MODEL_FAST=qwen2.5:7b-instruct
LLM_MODEL_BALANCED=llama3.1:8b-instruct
LLM_MODEL_QUALITY=llama3.1:70b-instruct
# LLM_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:14b-instruct

# Yandex Market
# auth mode: api-key | oauth | bearer
# or auto (tries api-key, oauth, bearer)
YANDEX_MARKET_AUTH_MODE=auto
YANDEX_MARKET_API_TOKEN=
# YANDEX_MARKET_TOKEN=
# YANDEX_MARKET_BUSINESS_ID=
# YANDEX_BUSINESS_ID=

# Ozon Seller
# auth mode: api-key | bearer | auto
OZON_AUTH_MODE=auto
# OZON_ACCESS_TOKEN=   # if using OAuth bearer token
OZON_API_KEY=
OZON_CLIENT_ID=
# OZON_TOKEN=
# Secondary account, if used:
# OZON_API_KEY_SECONDARY=
# OZON_CLIENT_ID_SECONDARY=
# OZON_ACCESS_TOKEN_SECONDARY=
# OZON_TOKEN_SECONDARY=

# ComfyUI
COMFYUI_BASE_URL=http://127.0.0.1:8188
# COMFYUI_API_KEY=

# Import tuning
INGEST_BATCH_SLEEP=0
INGEST_DOWNLOAD_TIMEOUT=30
INGEST_FLUSH_EVERY=20
INGEST_MAX_REWRITES=500
